# ─── Core ────────────────────────────────────────────────────────────────
PAYLOAD_SECRET=""

# ─── Domain & Google Search Console ──────────────────────────────────────
# The ONLY official domain (double "s": lifes-s-tyles). No trailing slash.
SITE_BASE_URL="https://www.healthylifesstyles.com"
# GSC property. Use sc-domain: for a Domain property, or https://.../ for URL-prefix.
GSC_SITE_URL="sc-domain:healthylifesstyles.com"
# Path to the GSC service-account JSON key (gitignored, never committed).
GSC_SERVICE_ACCOUNT_KEY_PATH="./secrets/gsc-sa.json"
# PostgreSQL connection string (Neon, Supabase, etc.). For Supabase use the
# 5432 SESSION pooler (persistent server). SSL is handled by the adapter, so no
# ?sslmode is needed. Set identically locally and on Hostinger. The schema is
# applied MANUALLY with `npm run migrate` — the build no longer auto-migrates.
DATABASE_URI="postgres://USER:PASSWORD@HOST/DBNAME"
# Payload dev schema auto-push (push:true). OFF by default to protect the
# production schema from accidental mutation/drops. Set "true" ONLY when running
# locally against a THROWAWAY dev database.
ALLOW_DB_PUSH="false"
NEXT_PUBLIC_SITE_URL="https://www.healthylifesstyles.com"

# ─── Persistent media storage (Cloudflare R2 or AWS S3) ──────────────────────
# Uploads persist OUTSIDE Hostinger's app folder so they survive redeploys.
# All four of S3_BUCKET/S3_ENDPOINT/S3_ACCESS_KEY_ID/S3_SECRET_ACCESS_KEY must be
# set to enable bucket storage; otherwise the CMS falls back to local storage.
S3_BUCKET=""
# Cloudflare R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# AWS S3:        https://s3.<region>.amazonaws.com
S3_ENDPOINT=""
S3_REGION="auto"                # R2 uses "auto"; AWS uses e.g. "us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Public base URL for absolute media links so the Astro site loads them directly.
# R2: the bucket's public r2.dev URL or a custom media domain (e.g. https://media.healthylifesstyles.com)
# AWS: https://<bucket>.s3.<region>.amazonaws.com (bucket must allow public read)
# Leave blank to serve media through the CMS instead (relative URLs).
S3_PUBLIC_URL=""

# ─── Google Search Console & Indexing API ────────────────────────────────
# The WHOLE service-account JSON file, base64-encoded to ONE line (newline-proof;
# raw JSON in env UIs corrupts the private_key's \n escapes). NEVER commit the
# real value. Encode the rotated key file with:
#   Linux/macOS:  base64 -w0 service-account.json
#   PowerShell:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
GOOGLE_INDEXING_CREDENTIALS_B64=""
# The verified GSC property — BYTE-EXACT match with Search Console required.
# Either form: "sc-domain:healthylifesstyles.com" (Domain property) or
# "https://www.healthylifesstyles.com/" (URL-prefix property, trailing slash
# REQUIRED). Validated at startup by src/lib/site-config.ts. No fallback to
# NEXT_PUBLIC_SITE_URL any more (its slash-less form can never match a
# URL-prefix property — that substitution caused blanket "Permission denied").
GSC_SITE_URL=""
# Set "true" TEMPORARILY to enable GET /api/seo/test-credentials (admin-only
# GSC self-diagnosis: credential source, accessible properties, live inspect).
# The route returns 404 whenever this is unset — leave OFF in production.
SEO_DEBUG_ENDPOINTS=""

# ─── AI providers (optional; generation degrades gracefully if unset) ─────
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
NARAROUTER_API_KEY=""
NARAROUTER_MODEL="mimo-v2.5-free"
DEEPSEEK_API_KEY=""
ZAI_API_KEY=""
ZAI_MODEL="glm-4-plus"
LOCAL_AI_BASE_URL="http://localhost:11434/v1"
LOCAL_AI_MODEL="gemma3"

# ─── Optional integrations ────────────────────────────────────────────────
OPENAI_API_KEY=""
FAL_KEY=""
IMAGE_PROVIDER="openai"
TAVILY_API_KEY=""
INTERNAL_API_KEY=""

# ─── USDA FoodData Central (Recipe Nutrition Analyzer) ─────────────────────
# Get a free API key at https://fdc.nal.usda.gov/api-key.html
# Leave empty to disable the recipe analyzer (the tool shows a config error).
USDA_FDC_API_KEY=""

# ─── Recipe AI parser (NaraRouter gateway) ───────────────────────────────
# The recipe parser uses NaraRouter (router.bynara.id), NOT direct DeepSeek.
# Get a key at https://router.bynara.id
NARAROUTER_API_KEY=""
NARAROUTER_BASE_URL="https://router.bynara.id/v1"
# Model for recipe parsing. "claude-sonnet-4.6" = FREE on the Free plan.
# Fallback: "deepseek-v4-flash" (Included). Override with AI_PARSE_MODEL.
AI_PARSE_MODEL="claude-sonnet-4.6"

# ─── Vercel Deploy Hook ─────────────────────────────────────────────────────
# Used by the manual Deploy button (§7.2), NOT auto-fired on every save.
# Create a deploy hook URL in Vercel Dashboard → Settings → Git → Deploy Hooks.
# Leave empty in development. NEVER prefix with NEXT_PUBLIC_ — server-only.
VERCEL_DEPLOY_HOOK_URL=""

# ─── AI SEO Autopilot (Phase 1) ─────────────────────────────────────────────
# Gemini API key for the audit crawler's AI-powered detectors.
# Get a key at https://aistudio.google.com/apikey
# NEVER prefix with NEXT_PUBLIC_ — server-only.
GEMINI_API_KEY=""
