# value — set it in your host's environment-variable UI (Vercel/Hostinger).
# Example shape (placeholder only):
# GOOGLE_INDEXING_CREDENTIALS='{"client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","project_id":"..."}'
GOOGLE_INDEXING_CREDENTIALS=""
# The verified GSC property (defaults to NEXT_PUBLIC_SITE_URL if unset).
